{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "files": {
    "includes": ["src/**", "*.ts", "*.json", "*.html", "tsconfig.*.json"]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "css": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "linter": {
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "useNodejsImportProtocol": "off",
        "noDescendingSpecificity": "off"
      },
      "suspicious": {
        "noControlCharactersInRegex": "off"
      },
      "complexity": {
        "noImportantStyles": "off"
      },
      "a11y": {
        "useMediaCaption": "off"
      }
    }
  }
}
