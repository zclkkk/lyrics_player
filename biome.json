{
	"$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"include": [
			"src/**/*.ts",
			"src/**/*.tsx",
			"src/**/*.json",
			"biome.json",
			"vite.config.ts",
			"index.html"
		]
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExplicitAny": "off",
				"noControlCharactersInRegex": "off"
			},
			"style": {
				"noNonNullAssertion": "off",
				"useSingleVarDeclarator": "off"
			},
			"complexity": {
				"noForEach": "off"
			}
		}
	},
	"organizeImports": {
		"enabled": true
	}
}
